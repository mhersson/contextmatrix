# ContextMatrix configuration example.
# Copy this file to one of the following locations:
#   $XDG_CONFIG_HOME/contextmatrix/config.yaml   (if XDG_CONFIG_HOME is set)
#   ~/.config/contextmatrix/config.yaml           (XDG default)
#   ./config.yaml                                 (current working directory fallback)
#
# Environment variable overrides are available for every field — see the
# CONTEXTMATRIX_* variables documented below.

# TCP port the HTTP server listens on.
# Default: 8080
# Env: CONTEXTMATRIX_PORT
port: 8080

# Path to the directory containing agent skill files (markdown).
# When left empty, defaults to a "skills" directory next to this config file.
# Tilde expansion is supported.
# Env: CONTEXTMATRIX_SKILLS_DIR
skills_dir: skills

# How long an agent can go without sending a heartbeat before the card is
# automatically moved to the "stalled" state and the agent claim is released.
# Accepts Go duration strings: e.g. "15m", "30m", "1h".
# Default: 30m
# Env: CONTEXTMATRIX_HEARTBEAT_TIMEOUT
heartbeat_timeout: "30m"

# Allowed origin for CORS requests. Set to the URL of your web UI in
# production. In development with Vite the default matches the dev server.
# Default: http://localhost:5173
# Env: CONTEXTMATRIX_CORS_ORIGIN
cors_origin: "http://localhost:5173"

# Per-model token cost rates used for usage reporting (optional).
# Keys are model identifiers; prompt/completion values are USD per token.
# Example rates below are illustrative — check Anthropic pricing for current values.
token_costs:
  claude-haiku-4-5:   { prompt: 0.0000008, completion: 0.000004  }
  claude-sonnet-4-6:  { prompt: 0.000003,  completion: 0.000015  }
  claude-opus-4-6:    { prompt: 0.000005,  completion: 0.000025  }

# Optional API key for MCP endpoint authentication.
# When set, all MCP requests must include this key in the Authorization header
# as "Bearer <key>". Leave empty to disable MCP authentication (current behavior).
# Env: CONTEXTMATRIX_MCP_API_KEY
mcp_api_key: ""

# Boards repository configuration.
# All settings below relate to the boards git repository — the separate repo
# that stores your kanban cards and project configs.
boards:
  # Path to the directory that holds your boards (a separate git repository).
  # This field is required — the server will not start without it.
  # Tilde expansion is supported (e.g. ~/contextmatrix-boards).
  # Env: CONTEXTMATRIX_BOARDS_DIR
  dir: ~/contextmatrix-boards

  # Automatically create a git commit in the boards repository after every card
  # mutation. Disable only if you manage commits yourself.
  # Default: true
  # Env: CONTEXTMATRIX_GIT_AUTO_COMMIT (true/false/1/0)
  git_auto_commit: true

  # Defer git commits: instead of committing after every write, accumulate changes
  # and commit them together when a task transitions to a terminal state (done,
  # not_planned). Reduces commit noise for tasks with many intermediate updates.
  # Has no effect unless git_auto_commit is also true.
  # Default: false
  # Env: CONTEXTMATRIX_GIT_DEFERRED_COMMIT (true/false/1/0)
  git_deferred_commit: false

  # Push commits to the remote after each commit. Requires the boards repository
  # to have a configured remote and credentials (e.g. SSH key).
  # Default: false
  # Env: CONTEXTMATRIX_GIT_AUTO_PUSH (true/false/1/0)
  git_auto_push: false

  # Pull from the remote on startup and at the interval defined by
  # git_pull_interval. Useful for sharing a board across multiple machines.
  # Default: false
  # Env: CONTEXTMATRIX_GIT_AUTO_PULL (true/false/1/0)
  git_auto_pull: false

  # How often to pull from the remote when git_auto_pull is enabled.
  # Accepts Go duration strings: e.g. "30s", "5m", "1h".
  # Default: 60s
  # Env: CONTEXTMATRIX_GIT_PULL_INTERVAL
  git_pull_interval: "60s"

  # Clone the boards repository from a remote URL if boards.dir is empty
  # (no existing git repository). Useful for container deployments where
  # persistent storage starts empty. Requires boards.git_remote_url to be set.
  # Default: false
  # Env: CONTEXTMATRIX_GIT_CLONE_ON_EMPTY (true/false/1/0)
  git_clone_on_empty: false

  # Remote URL for the boards repository. Used for clone-on-empty and as
  # the default origin remote when no remote is configured.
  # Example (SSH):   git@github.com:user/boards.git
  # Example (HTTPS): https://github.com/user/boards.git
  # Env: CONTEXTMATRIX_GIT_REMOTE_URL
  git_remote_url: ""

  # Authentication mode for git operations on the boards repository.
  # Allowed values: "ssh" (default) | "pat"
  #
  #   ssh — Use an SSH deploy key already configured in the git environment
  #          (e.g. ~/.ssh/id_rsa). No additional configuration required beyond
  #          the key being present and trusted by the remote host.
  #
  #   pat — Inject a GitHub fine-grained Personal Access Token via the
  #          GIT_CONFIG_COUNT / GIT_CONFIG_KEY_0 / GIT_CONFIG_VALUE_0 env
  #          variables (http.extraheader=Authorization: Bearer <token>).
  #          The token is NEVER embedded in boards.git_remote_url, keeping it
  #          out of process argument lists and git config files on disk.
  #
  #          Required PAT permissions:
  #            boards repository : contents:write   (clone, pull, push)
  #            project repos     : issues:read      (GitHub issue import)
  #
  #          When pat is selected:
  #            • github.token must be non-empty
  #            • boards.git_remote_url must start with https://
  #
  # Default: ssh
  # Env: CONTEXTMATRIX_BOARDS_GIT_AUTH_MODE
  git_auth_mode: "ssh"

# PAT example — to activate PAT auth for the boards repo:
#   1. In the boards: section above, set:
#        git_auth_mode: "pat"
#        git_remote_url: "https://github.com/your-org/boards.git"
#   2. Set github.token via the CONTEXTMATRIX_GITHUB_TOKEN env var — never hard-code

# Remote execution runner configuration.
# The runner is a separate binary (contextmatrix-runner) that executes
# autonomous tasks in disposable Docker containers. See docs/remote-execution.md.
runner:
  # Enable remote execution integration.
  # Default: false
  # Env: CONTEXTMATRIX_RUNNER_ENABLED
  enabled: false

  # Base URL of the runner. Fixed paths are appended: /trigger, /kill, /stop-all.
  # Example: http://localhost:9090
  # Env: CONTEXTMATRIX_RUNNER_URL
  url: ""

  # Shared secret for webhook HMAC-SHA256 signing (runner <-> CM authentication).
  # Must match the runner's configured api_key. Never transmitted over the wire.
  # Must be at least 32 characters when runner is enabled.
  # Env: CONTEXTMATRIX_RUNNER_API_KEY
  api_key: ""

  # Public URL of this ContextMatrix instance, as reachable from runner containers.
  # The runner passes this to spawned containers so they can connect to the MCP endpoint.
  # Example: http://contextmatrix:8080 (Docker network), https://cm.example.com (remote)
  # Required when runner is enabled.
  # Env: CONTEXTMATRIX_RUNNER_PUBLIC_URL
  public_url: ""

# GitHub integration configuration.
# A fine-grained PAT (token) is used both for reading branches and for importing
# issues. The token is always required when any GitHub feature is in use.
github:
  # GitHub personal access token (fine-grained recommended).
  # Required when github.issue_importing.enabled is true.
  # Also used for branch listing even when issue importing is disabled.
  # Env: CONTEXTMATRIX_GITHUB_TOKEN
  token: ""

  # GitHub Enterprise Cloud with Data Residency (GHEC-DR) or GitHub Enterprise
  # Server hostname. Leave empty for standard github.com.
  # Example: acme.ghe.com
  # Env: CONTEXTMATRIX_GITHUB_HOST
  # host: acme.ghe.com

  # GitHub API base URL. When left empty, derived from host:
  #   host empty     → https://api.github.com
  #   host set       → https://api.<host>
  # Set explicitly only when your enterprise instance uses a non-standard URL.
  # Example: https://api.acme.ghe.com
  # Env: CONTEXTMATRIX_GITHUB_API_BASE_URL
  # api_base_url: https://api.acme.ghe.com

  # Issue importing configuration.
  # When enabled, ContextMatrix periodically fetches open GitHub issues and
  # creates cards in projects that have github.import_issues set in .board.yaml.
  issue_importing:
    # Enable periodic GitHub issue import.
    # Requires github.token to be set.
    # Default: false
    # Env: CONTEXTMATRIX_GITHUB_ISSUE_IMPORTING_ENABLED
    enabled: false

    # How often to check GitHub for new issues.
    # Accepts Go duration strings: e.g. "5m", "10m", "15m".
    # Minimum: 5m. Default: 5m
    # Env: CONTEXTMATRIX_GITHUB_ISSUE_IMPORTING_SYNC_INTERVAL
    sync_interval: "5m"
