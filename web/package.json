{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "size": "size-limit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "size-limit": [
    {
      "name": "md-editor chunk (lazy, fetched on first editor open)",
      "path": "dist/assets/md-editor-*.js",
      "limit": "350 kB"
    },
    {
      "name": "ProjectShell chunk (main app shell, critical path)",
      "path": "dist/assets/ProjectShell-*.js",
      "limit": "40 kB"
    },
    {
      "name": "React runtime chunk",
      "path": "dist/assets/react-*.js",
      "limit": "80 kB"
    }
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@uiw/react-markdown-preview": "^5.2.0",
    "@uiw/react-md-editor": "^4.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
